# Copy to .env and fill in. VITE_-prefixed values ship in the client bundle (public);
# everything else stays server/script-side only.
VITE_REOWN_PROJECT_ID=your-reown-project-id
VITE_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# scripts only - NEVER expose with a VITE_ prefix
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
